# Test environment template.
# Used by deployment/compose.test.yaml. The isolated stack uses a one-second
# viewing window so challenge timing can be exercised deterministically.

APP_ENV=test
PORT=8080
PUBLIC_URL=http://localhost:8080
LOG_LEVEL=info

DATABASE_URL=postgres://test:test@db:5432/geoguessme_test?sslmode=disable
DB_MIN_CONNS=2
DB_MAX_CONNS=10

JWT_SECRET=test_secret_key_at_least_32_characters_long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
VERIFICATION_TOKEN_TTL=24h
RESET_TOKEN_TTL=1h
BCRYPT_COST=4

ALLOWED_ORIGINS=http://localhost:8080
TRUSTED_PROXY_CIDRS=
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=1m

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=geoguessme-test-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true
STORAGE_DRIVER=
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_MAX_PIXELS=25000000

CHALLENGE_TTL=24h
PHOTO_VIEW_WINDOW=1s
PHOTO_RETENTION=720h

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=no-reply@test.local
SMTP_TLS=off
SMTP_DIAL_TIMEOUT=10s
SMTP_TIMEOUT=30s
