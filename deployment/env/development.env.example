# Development environment template.
# Copy to deployment/env/development.env (or .env at the repo root) and adjust.
# All variables are optional in development; sensible MinIO/Mailpit defaults apply.

APP_ENV=development
PORT=8080
PUBLIC_URL=http://localhost:5173
LOG_LEVEL=info

# PostgreSQL 15 development database.
DATABASE_URL=postgres://user:password@localhost:5432/geoguessme?sslmode=disable
DB_MIN_CONNS=2
DB_MAX_CONNS=10

# Generate with: openssl rand -base64 48
JWT_SECRET=dev_secret_key_change_me_please_32_characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
VERIFICATION_TOKEN_TTL=24h
RESET_TOKEN_TTL=1h
BCRYPT_COST=10

# Browser origins allowed for CORS and WebSocket upgrades.
ALLOWED_ORIGINS=http://localhost:5173
# Comma-separated CIDRs trusted to set X-Forwarded-For/X-Real-IP (empty in dev).
TRUSTED_PROXY_CIDRS=
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=1m

# MinIO locally; use a private S3-compatible bucket in production.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=geoguessme-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true
# Set to "local" to store media on disk instead of S3.
STORAGE_DRIVER=
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_MAX_PIXELS=25000000

# Gameplay timing.
CHALLENGE_TTL=24h
PHOTO_VIEW_WINDOW=10s
PHOTO_RETENTION=720h

# Mailpit locally; production requires authenticated SMTP with TLS.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@localhost
# One of: off | starttls | tls (off only valid outside production).
SMTP_TLS=off
SMTP_DIAL_TIMEOUT=10s
SMTP_TIMEOUT=30s

# Web Push: optional in development (ephemeral keys are generated at startup).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@localhost
