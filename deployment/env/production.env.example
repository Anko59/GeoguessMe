# Production environment template.
# Copy to deployment/env/production.env and fill every value. Every variable
# below is REQUIRED in production; the backend refuses to start otherwise.

APP_ENV=production
PORT=8080
PUBLIC_URL=https://geoguessme.com
LOG_LEVEL=info

POSTGRES_USER=geoguessme
POSTGRES_PASSWORD=replace-with-random-password
POSTGRES_DB=geoguessme
DATABASE_URL=postgres://geoguessme:replace-with-url-escaped-password@postgres/geoguessme?sslmode=disable
DB_MIN_CONNS=2
DB_MAX_CONNS=10

# openssl rand -base64 48
JWT_SECRET=replace-with-output-of-openssl-rand-base64-48
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
VERIFICATION_TOKEN_TTL=24h
RESET_TOKEN_TTL=1h
BCRYPT_COST=12

ALLOWED_ORIGINS=https://geoguessme.com
TRUSTED_PROXY_CIDRS=172.16.0.0/12
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=1m

# Private S3-compatible bucket. HTTPS endpoint only in production.
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=geoguessme-production-media
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_USE_PATH_STYLE=true
UPLOAD_MAX_BYTES=5242880
UPLOAD_MAX_PIXELS=25000000

CHALLENGE_TTL=24h
PHOTO_VIEW_WINDOW=10s
PHOTO_RETENTION=720h

# Authenticated SMTP. TLS mode MUST be starttls or tls in production.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=replace-me
SMTP_PASSWORD=replace-me
SMTP_FROM=no-reply@geoguessme.com
SMTP_TLS=starttls
SMTP_DIAL_TIMEOUT=10s
SMTP_TIMEOUT=30s

# openssl rand -hex 32
METRICS_TOKEN=replace-with-output-of-openssl-rand-hex-32
GHCR_USERNAME=replace-me
GHCR_TOKEN=replace-with-read-packages-token

# Encrypted PostgreSQL backups in the private R2 backup bucket.
RESTIC_REPOSITORY=s3:https://ACCOUNT_ID.r2.cloudflarestorage.com/geoguessme-database-backups/production
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
RESTIC_PASSWORD=replace-with-random-backup-secret
