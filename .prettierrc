{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 4,
  "printWidth": 120,
  "arrowParens": "always",
  "overrides": [
    { "files": "*.md", "options": { "proseWrap": "always", "printWidth": 80 } },
    { "files": "*.{yml,yaml}", "options": { "tabWidth": 2, "singleQuote": false } },
    { "files": "*.json", "options": { "tabWidth": 2, "singleQuote": false } }
  ]
}
