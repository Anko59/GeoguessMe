# --- Local storage, database dumps, backups ---
/backend/uploads/*
!/backend/uploads/.keep
*.sql
*.sql.gz
*.dump
# Database migrations are embedded into the backend binary and must be tracked.
!backend/internal/database/migrations/
!backend/internal/database/migrations/**
# Legacy migration fixture for deterministic migration testing.
!deployment/scripts/legacy-migration-fixture.sql
/backups/

# --- Docker / Compose local overrides ---
docker-compose.override.yml
docker-compose.override.yaml
deployment/compose.*.override.yaml

# --- Editor / OS ---
.idea/
.vscode/
*.swp

# Pi tooling session state
.pi/
.pi-subagents/
